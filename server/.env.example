# Copy to .env and fill in values
FLASK_SECRET_KEY=change-me-to-a-random-string
SCRIPTS_DIR=D:/JARVIS back up 16092025/JARVIS backup/Code - Full set
# DATABASE_URL defaults to sqlite in instance/app.db (absolute path).
# Override only for Postgres, e.g.:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
SESSION_HOURS=8
JOB_RETENTION_HOURS=24

# --- Security (tune for production) ---
FORCE_HTTPS=false                # set to true on Render (HTTPS is forced there)
LOGIN_RATE_LIMIT=5 per minute    # Flask-Limiter format
MAX_FAILED_LOGINS=5              # per-account lockout threshold
LOCKOUT_MINUTES=15               # how long an account stays locked
